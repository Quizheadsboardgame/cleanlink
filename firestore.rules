
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isProcessor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_processor/$(request.auth.uid));
    }

    function isSettingCorrectOwner(data) {
      return data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/stockOrders/{stockOrderId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isSettingCorrectOwner(request.resource.data);
      allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isExistingOwner(userId);

      match /orderItems/{orderItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isSettingCorrectOwner(request.resource.data);
        allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /users/{userId}/faultyEquipmentReports/{reportId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isSettingCorrectOwner(request.resource.data);
      allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isExistingOwner(userId);
    }

    match /orderTasks/{orderTaskId} {
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isProcessor());
      allow create: if isSignedIn() && isSettingCorrectOwner(request.resource.data);
      allow update: if (isProcessor() || (isSignedIn() && resource.data.ownerId == request.auth.uid)) && resource != null;
      allow delete: if isProcessor() && resource != null;
    }

    match /roles_processor/{processorId} {
      allow get: if isSignedIn();
      allow list: if isProcessor();
      allow create, update, delete: if false;
    }
  }
}
