
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Manager access keys - used for site linking and portal entry
    match /managerKeys/{keyId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Tickets for Control Room oversight
    match /controlRoomTickets/{ticketId} {
      allow read, write: if true;
    }

    // Tasks for management visibility (Orders, Reports, Inquiries)
    match /orderTasks/{taskId} {
      allow read, write: if true;
    }

    // Public staff appreciation board
    match /kudos/{kudosId} {
      allow read, write: if true;
    }

    // Management announcements and site-specific protocols
    match /importantInfo/{infoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Global system alerts scrolling banner
    match /systemAlerts/{alertId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Cover work opportunities and staff responses
    match /coverWorkPosts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
      match /responses/{responseId} {
        allow read, write: if true;
      }
    }

    // Private staff concern reports
    match /staffConcerns/{concernId} {
      allow read, write: if true;
    }

    // User Private Data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
