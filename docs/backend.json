{
  "entities": {
    "ManagerKey": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ManagerKey",
      "type": "object",
      "description": "A unique access key for a manager created in the Control Room.",
      "properties": {
        "id": { "type": "string" },
        "key": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "key", "displayName", "createdAt"]
    },
    "StockOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StockOrder",
      "type": "object",
      "description": "Represents a user-created stock order containing multiple items for a specific site, before or after submission.",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "site": { "type": "string" },
        "status": { "type": "string" },
        "needStoresDelivered": { "type": "boolean" },
        "isPickedUp": { "type": "boolean" },
        "pickupLocation": { "type": "string" },
        "managerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerName", "orderDate", "site", "status", "createdAt"]
    },
    "OrderTask": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrderTask",
      "type": "object",
      "description": "Represents a task generated upon submission of a report.",
      "properties": {
        "id": { "type": "string" },
        "stockOrderId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "managerNote": { "type": "string" },
        "managerId": { "type": "string" },
        "assignedToUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "type": {
          "type": "string",
          "enum": ["Stock Order", "Faulty Equipment", "Incomplete Task", "Additional Hours", "Staff Referral", "Staff Concern"]
        }
      },
      "required": ["id", "stockOrderId", "title", "description", "status", "createdAt"]
    },
    "StaffKudos": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StaffKudos",
      "type": "object",
      "description": "A public appreciation note from one staff member to another.",
      "properties": {
        "id": { "type": "string" },
        "senderName": { "type": "string" },
        "recipientName": { "type": "string" },
        "message": { "type": "string" },
        "managerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderName", "recipientName", "message", "createdAt"]
    },
    "SystemAlert": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SystemAlert",
      "type": "object",
      "description": "Global broadcast message set by management.",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "active": { "type": "boolean" },
        "managerId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "message", "active", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/managerKeys/{keyId}",
        "definition": {
          "entityName": "ManagerKey",
          "schema": { "$ref": "#/backend/entities/ManagerKey" },
          "description": "Unique access keys for managers managed by Control Room."
        }
      },
      {
        "path": "/staffConcerns/{concernId}",
        "definition": {
          "entityName": "StaffConcern",
          "schema": { "$ref": "#/backend/entities/StaffConcern" },
          "description": "Private concerns submitted by staff."
        }
      },
      {
        "path": "/orderTasks/{taskId}",
        "definition": {
          "entityName": "OrderTask",
          "schema": { "$ref": "#/backend/entities/OrderTask" },
          "description": "Tasks for management."
        }
      },
      {
        "path": "/kudos/{kudosId}",
        "definition": {
          "entityName": "StaffKudos",
          "schema": { "$ref": "#/backend/entities/StaffKudos" },
          "description": "Public staff appreciation board."
        }
      },
      {
        "path": "/systemAlerts/{alertId}",
        "definition": {
          "entityName": "SystemAlert",
          "schema": { "$ref": "#/backend/entities/SystemAlert" },
          "description": "Global notification alerts."
        }
      }
    ]
  }
}
