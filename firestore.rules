rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Manager Keys - Allow anyone to check a key (required for initial login gate)
    match /managerKeys/{keyId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Core Collections - Siloed by managerId in application logic
    // We allow read/write to prevent race condition crashes during anonymous sign-in
    match /orderTasks/{taskId} {
      allow read, write: if true;
    }

    match /importantInfo/{infoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /coverWorkPosts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
      match /responses/{responseId} {
        allow read, write: if true;
      }
    }

    match /staffConcerns/{concernId} {
      allow read, write: if true;
    }

    match /kudos/{kudosId} {
      allow read, write: if true;
    }

    match /systemAlerts/{alertId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // User Private Data - Strict ownership enforced
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}