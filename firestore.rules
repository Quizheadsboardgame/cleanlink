
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isSettingCorrectOwner(data) {
      return data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/stockOrders/{stockOrderId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      match /orderItems/{orderItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    match /users/{userId}/additionalHoursRequests/{requestId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/referrals/{referralId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/faultyEquipmentReports/{reportId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /users/{userId}/incompleteTaskReports/{reportId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    match /orderTasks/{orderTaskId} {
      allow get, list, update, delete: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /importantInfo/{infoId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /coverWorkPosts/{postId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();

      match /responses/{responseId} {
        allow create: if isSignedIn();
        allow get, list: if isSignedIn();
      }
    }

    match /staffConcerns/{concernId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if isSignedIn();
    }

    match /kudos/{kudosId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // Morale is permanent!
    }
  }
}
