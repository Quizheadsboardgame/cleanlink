
{
  "entities": {
    "ManagerKey": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ManagerKey",
      "type": "object",
      "description": "A unique access key for a manager created in the Control Room.",
      "properties": {
        "id": { "type": "string" },
        "key": { "type": "string" },
        "displayName": { "type": "string" },
        "enabledModules": {
          "type": "object",
          "description": "Visibility toggles for various app features.",
          "properties": {
            "stores": { "type": "boolean" },
            "faulty": { "type": "boolean" },
            "incomplete": { "type": "boolean" },
            "hours": { "type": "boolean" },
            "pay": { "type": "boolean" },
            "referral": { "type": "boolean" },
            "cover": { "type": "boolean" },
            "kudos": { "type": "boolean" },
            "concern": { "type": "boolean" },
            "info": { "type": "boolean" },
            "guide": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "key", "displayName", "createdAt"]
    },
    "ControlRoomTicket": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ControlRoomTicket",
      "type": "object",
      "description": "A support ticket raised by a manager to the Control Room staff.",
      "properties": {
        "id": { "type": "string" },
        "managerId": { "type": "string" },
        "managerName": { "type": "string" },
        "type": { "type": "string", "enum": ["Site Fault", "Feature Request", "Extra Training"] },
        "description": { "type": "string" },
        "controlRoomNote": { "type": "string", "description": "Feedback provided by the Control Room." },
        "status": { "type": "string", "enum": ["Open", "Resolved"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolvedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "managerId", "type", "description", "status", "createdAt"]
    },
    "StockOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StockOrder",
      "type": "object",
      "description": "Represents a user-created stock order containing multiple items for a specific site.",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "site": { "type": "string" },
        "status": { "type": "string" },
        "needStoresDelivered": { "type": "boolean" },
        "isPickedUp": { "type": "boolean" },
        "pickupLocation": { "type": "string" },
        "managerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerName", "orderDate", "site", "status", "createdAt"]
    },
    "PayError": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PayError",
      "type": "object",
      "description": "A report regarding missing pay or incorrect hours.",
      "properties": {
        "id": { "type": "string" },
        "cleanerName": { "type": "string" },
        "site": { "type": "string" },
        "siteCode": { "type": "string" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string" },
              "hours": { "type": "string" }
            }
          }
        },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "managerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "cleanerName", "site", "siteCode", "entries", "status", "createdAt"]
    },
    "OrderTask": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrderTask",
      "type": "object",
      "description": "Represents a task generated upon submission of a report or order.",
      "properties": {
        "id": { "type": "string" },
        "stockOrderId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "managerNote": { "type": "string", "description": "Public feedback visible to cleaners." },
        "privateNote": { "type": "string", "description": "Internal note visible only to managers." },
        "managerId": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "type": {
          "type": "string",
          "enum": ["Stock Order", "Faulty Equipment", "Incomplete Task", "Additional Hours", "Staff Referral", "Staff Concern", "Cover Interest", "Pay Enquiry"]
        }
      },
      "required": ["id", "title", "status", "createdAt", "managerId"]
    },
    "StaffKudos": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StaffKudos",
      "type": "object",
      "description": "A public appreciation note from one staff member to another, moderated by management.",
      "properties": {
        "id": { "type": "string" },
        "senderName": { "type": "string" },
        "recipientName": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending Review", "Authorised", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorisedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderName", "recipientName", "message", "createdAt", "status"]
    },
    "StaffConcern": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StaffConcern",
      "type": "object",
      "description": "A private concern report submitted by a staff member.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Staff Member", "Health & Safety", "Other"] },
        "site": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "managerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "site", "description", "status", "createdAt"]
    },
    "SystemAlert": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SystemAlert",
      "type": "object",
      "description": "Global broadcast message set by management.",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "active": { "type": "boolean" },
        "managerId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "message", "active", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/managerKeys/{keyId}",
        "definition": {
          "entityName": "ManagerKey",
          "schema": { "$ref": "#/backend/entities/ManagerKey" },
          "description": "Unique access keys for managers managed by Control Room."
        }
      },
      {
        "path": "/controlRoomTickets/{ticketId}",
        "definition": {
          "entityName": "ControlRoomTicket",
          "schema": { "$ref": "#/backend/entities/ControlRoomTicket" },
          "description": "Tickets raised by managers to the control room."
        }
      },
      {
        "path": "/orderTasks/{taskId}",
        "definition": {
          "entityName": "OrderTask",
          "schema": { "$ref": "#/backend/entities/OrderTask" },
          "description": "Tasks for management visibility."
        }
      },
      {
        "path": "/kudos/{kudosId}",
        "definition": {
          "entityName": "StaffKudos",
          "schema": { "$ref": "#/backend/entities/StaffKudos" },
          "description": "Public staff appreciation board."
        }
      },
      {
        "path": "/systemAlerts/{alertId}",
        "definition": {
          "entityName": "SystemAlert",
          "schema": { "$ref": "#/backend/entities/SystemAlert" },
          "description": "Global notification alerts siloed by manager."
        }
      },
      {
        "path": "/staffConcerns/{concernId}",
        "definition": {
          "entityName": "StaffConcern",
          "schema": { "$ref": "#/backend/entities/StaffConcern" },
          "description": "Private staff concern reports."
        }
      },
      {
        "path": "/users/{userId}/payErrors/{errorId}",
        "definition": {
          "entityName": "PayError",
          "schema": { "$ref": "#/backend/entities/PayError" },
          "description": "Individual payroll discrepancy reports."
        }
      }
    ]
  }
}
