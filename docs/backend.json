
{
  "entities": {
    "StockOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StockOrder",
      "type": "object",
      "description": "Represents a user-created stock order containing multiple items for a specific site, before or after submission.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the StockOrder entity."
        },
        "customerName": {
          "type": "string",
          "description": "The name of the customer or person placing the stock order."
        },
        "orderDate": {
          "type": "string",
          "description": "The date and time when the stock order was placed.",
          "format": "date-time"
        },
        "site": {
          "type": "string",
          "description": "The designated site or location for which the stock order is being placed."
        },
        "status": {
          "type": "string",
          "description": "The current workflow status of the stock order (e.g., 'Draft', 'Submitted', 'Archived'). 'Submitted' indicates a corresponding OrderTask has been created."
        },
        "needStoresDelivered": {
          "type": "boolean",
          "description": "Whether the items need to be delivered to the site."
        },
        "isPickedUp": {
          "type": "boolean",
          "description": "Whether the items were picked up from a specific location."
        },
        "pickupLocation": {
          "type": "string",
          "description": "The location where the items were picked up from, if applicable."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the stock order record was initially created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the stock order record was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "customerName",
        "orderDate",
        "site",
        "status",
        "createdAt"
      ]
    },
    "OrderItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrderItem",
      "type": "object",
      "description": "Represents a single item and its quantity within a specific stock order.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the OrderItem entity."
        },
        "stockOrderId": {
          "type": "string",
          "description": "Reference to the StockOrder this item belongs to. (Relationship: StockOrder 1:N OrderItem)"
        },
        "itemName": {
          "type": "string",
          "description": "The name or description of the item being ordered."
        },
        "quantity": {
          "type": "number",
          "description": "The numerical quantity of the item being ordered. Typically a positive integer."
        }
      },
      "required": [
        "id",
        "stockOrderId",
        "itemName",
        "quantity"
      ]
    },
    "OrderTask": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrderTask",
      "type": "object",
      "description": "Represents a task generated upon submission of a stock order, faulty equipment report, or incomplete task report.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the OrderTask entity."
        },
        "stockOrderId": {
          "type": "string",
          "description": "Reference to the associated report (StockOrder, FaultyEquipment, etc.)."
        },
        "title": {
          "type": "string",
          "description": "A concise title for the processing task."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the task."
        },
        "status": {
          "type": "string",
          "description": "The current workflow status of the task (e.g., 'Pending Review', 'In Progress', 'Completed', 'Rejected')."
        },
        "managerNote": {
          "type": "string",
          "description": "A public note added by a manager to provide updates on task progress."
        },
        "assignedToUserId": {
          "type": "string",
          "description": "Optional reference to the user assigned to complete this task."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the task was initially created.",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "description": "Timestamp indicating when the task was marked as completed.",
          "format": "date-time"
        },
        "type": {
          "type": "string",
          "description": "The category of task.",
          "enum": ["Stock Order", "Faulty Equipment", "Incomplete Task", "Additional Hours", "Staff Referral"]
        }
      },
      "required": [
        "id",
        "stockOrderId",
        "title",
        "description",
        "status",
        "createdAt"
      ]
    },
    "FaultyEquipmentReport": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FaultyEquipmentReport",
      "type": "object",
      "description": "A report submitted by a cleaner to request replacement of faulty equipment.",
      "properties": {
        "id": { "type": "string" },
        "cleanerName": { "type": "string" },
        "site": { "type": "string" },
        "equipmentName": { "type": "string" },
        "faultDescription": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "cleanerName", "site", "equipmentName", "faultDescription", "status", "ownerId", "createdAt"]
    },
    "IncompleteTaskReport": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "IncompleteTaskReport",
      "type": "object",
      "description": "A report explaining why a cleaning task could not be completed.",
      "properties": {
        "id": { "type": "string" },
        "cleanerName": { "type": "string" },
        "site": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "cleanerName", "site", "reason", "status", "ownerId", "createdAt"]
    },
    "AdditionalHoursRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdditionalHoursRequest",
      "type": "object",
      "description": "A request submitted by a cleaner for permanent or temporary extra working hours.",
      "properties": {
        "id": { "type": "string" },
        "cleanerName": { "type": "string" },
        "site": { "type": "string" },
        "requestType": { "type": "string", "enum": ["Permanent", "Temporary"] },
        "datesFree": { "type": "string" },
        "timesAvailable": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "cleanerName", "site", "requestType", "timesAvailable", "status", "ownerId", "createdAt"]
    },
    "StaffReferral": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StaffReferral",
      "type": "object",
      "description": "A referral for a friend or family member to join the cleaning team.",
      "properties": {
        "id": { "type": "string" },
        "referrerName": { "type": "string" },
        "friendName": { "type": "string" },
        "friendEmail": { "type": "string", "format": "email" },
        "friendPhone": { "type": "string" },
        "extraInfo": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "referrerName", "friendName", "friendEmail", "friendPhone", "status", "ownerId", "createdAt"]
    },
    "ImportantInfo": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ImportantInfo",
      "type": "object",
      "description": "General information, contact details, or announcements for staff.",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string", "enum": ["Management", "Procedures", "Announcements"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "category", "title", "content", "updatedAt"]
    },
    "CoverWorkPost": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CoverWorkPost",
      "type": "object",
      "description": "A post created by a manager for upcoming cover work opportunities.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "deadline", "createdAt"]
    },
    "CoverWorkResponse": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CoverWorkResponse",
      "type": "object",
      "description": "A response from a cleaner expressing interest in a cover work post.",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "cleanerName": { "type": "string" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "postId", "cleanerName", "ownerId", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/stockOrders/{stockOrderId}",
        "definition": {
          "entityName": "StockOrder",
          "schema": {
            "$ref": "#/backend/entities/StockOrder"
          },
          "description": "Stores individual stock orders created by a user.",
          "params": [
            { "name": "userId", "description": "Owner UID" },
            { "name": "stockOrderId", "description": "Order UID" }
          ]
        }
      },
      {
        "path": "/users/{userId}/additionalHoursRequests/{requestId}",
        "definition": {
          "entityName": "AdditionalHoursRequest",
          "schema": {
            "$ref": "#/backend/entities/AdditionalHoursRequest"
          },
          "description": "Stores requests for additional working hours.",
          "params": [
            { "name": "userId", "description": "Owner UID" },
            { "name": "requestId", "description": "Request UID" }
          ]
        }
      },
      {
        "path": "/users/{userId}/referrals/{referralId}",
        "definition": {
          "entityName": "StaffReferral",
          "schema": {
            "$ref": "#/backend/entities/StaffReferral"
          },
          "description": "Stores friend referrals submitted by staff.",
          "params": [
            { "name": "userId", "description": "Owner UID" },
            { "name": "referralId", "description": "Referral UID" }
          ]
        }
      },
      {
        "path": "/users/{userId}/faultyEquipmentReports/{reportId}",
        "definition": {
          "entityName": "FaultyEquipmentReport",
          "schema": {
            "$ref": "#/backend/entities/FaultyEquipmentReport"
          },
          "description": "Stores faulty equipment reports submitted by cleaners.",
          "params": [
            { "name": "userId", "description": "Owner UID" },
            { "name": "reportId", "description": "Report UID" }
          ]
        }
      },
      {
        "path": "/users/{userId}/incompleteTaskReports/{reportId}",
        "definition": {
          "entityName": "IncompleteTaskReport",
          "schema": {
            "$ref": "#/backend/entities/IncompleteTaskReport"
          },
          "description": "Stores reports regarding incomplete cleaning tasks.",
          "params": [
            { "name": "userId", "description": "Owner UID" },
            { "name": "reportId", "description": "Report UID" }
          ]
        }
      },
      {
        "path": "/orderTasks/{orderTaskId}",
        "definition": {
          "entityName": "OrderTask",
          "schema": {
            "$ref": "#/backend/entities/OrderTask"
          },
          "description": "Unified tasks for reviewing orders, equipment, and referrals.",
          "params": [
            { "name": "orderTaskId", "description": "Task UID" }
          ]
        }
      },
      {
        "path": "/importantInfo/{infoId}",
        "definition": {
          "entityName": "ImportantInfo",
          "schema": {
            "$ref": "#/backend/entities/ImportantInfo"
          },
          "description": "General information accessible to all users.",
          "params": [
            { "name": "infoId", "description": "Info UID" }
          ]
        }
      },
      {
        "path": "/coverWorkPosts/{postId}",
        "definition": {
          "entityName": "CoverWorkPost",
          "schema": {
            "$ref": "#/backend/entities/CoverWorkPost"
          },
          "description": "Managers' posts for cover work.",
          "params": [
            { "name": "postId", "description": "Post UID" }
          ]
        }
      },
      {
        "path": "/coverWorkPosts/{postId}/responses/{responseId}",
        "definition": {
          "entityName": "CoverWorkResponse",
          "schema": {
            "$ref": "#/backend/entities/CoverWorkResponse"
          },
          "description": "Cleaners' responses to cover work posts.",
          "params": [
            { "name": "postId", "description": "Post UID" },
            { "name": "responseId", "description": "Response UID" }
          ]
        }
      }
    ]
  }
}
