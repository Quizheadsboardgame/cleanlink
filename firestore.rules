
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    match /users/{userId}/stockOrders/{stockOrderId} {
      allow get, list, create, update, delete: if isOwner(userId);
      match /orderItems/{orderItemId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    match /users/{userId}/additionalHoursRequests/{requestId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/referrals/{referralId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/faultyEquipmentReports/{reportId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/incompleteTaskReports/{reportId} {
      allow get, list, create, update, delete: if isOwner(userId);
    }

    match /orderTasks/{orderTaskId} {
      allow create: if isSignedIn();
      // Only the manager assigned to the task can see/edit it
      allow get, list, update, delete: if isSignedIn() && (resource.data.managerId == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }

    match /importantInfo/{infoId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /coverWorkPosts/{postId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();

      match /responses/{responseId} {
        allow create: if isSignedIn();
        allow get, list: if isSignedIn();
      }
    }

    match /staffConcerns/{concernId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if isSignedIn() && resource.data.managerId == request.auth.uid;
    }

    match /kudos/{kudosId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /systemAlerts/{alertId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
