rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Shared Infrastructure - Allow read to all authenticated users to prevent hydration/race crashes
    // Siloing is enforced at the application query level via managerId
    match /managerKeys/{keyId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /orderTasks/{taskId} {
      allow read, write: if true;
    }

    match /importantInfo/{infoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /coverWorkPosts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
      match /responses/{responseId} {
        allow read, write: if true;
      }
    }

    match /staffConcerns/{concernId} {
      allow read, write: if true;
    }

    match /kudos/{kudosId} {
      allow read, write: if true;
    }

    match /systemAlerts/{alertId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // User Private Data - Strict ownership enforced
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}