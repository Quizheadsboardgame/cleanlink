rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Core Collections - Allow authenticated users to interact with infrastructure
    // These include list operations needed for the dashboards
    match /orderTasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    match /managerProfiles/{profileId} {
      allow read, write: if isSignedIn();
    }

    match /importantInfo/{infoId} {
      allow read, write: if isSignedIn();
    }

    match /coverWorkPosts/{postId} {
      allow read, write: if isSignedIn();
      match /responses/{responseId} {
        allow read, write: if isSignedIn();
      }
    }

    match /staffConcerns/{concernId} {
      allow read, write: if isSignedIn();
    }

    match /kudos/{kudosId} {
      allow read, write: if isSignedIn();
    }

    match /systemAlerts/{alertId} {
      allow read, write: if isSignedIn();
    }

    // User Private Data - Strict ownership enforced
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}